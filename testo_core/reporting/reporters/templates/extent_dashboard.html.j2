<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Testo Extent Report — {{ run_title }}</title>
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1e293b;
      --surface-2: #334155;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --pass: #22c55e;
      --fail: #ef4444;
      --broken: #f97316;
      --skip: #64748b;
      --accent: #6366f1;
      --radius: 12px;
      --shadow: 0 4px 24px rgba(0,0,0,.35);
    }
    html.light {
      --bg: #f8fafc;
      --surface: #ffffff;
      --surface-2: #e2e8f0;
      --text: #0f172a;
      --muted: #64748b;
      --shadow: 0 4px 24px rgba(15,23,42,.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Inter", system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
    header {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
      gap: 1rem; margin-bottom: 1.5rem; padding: 1.25rem 1.5rem;
      background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow);
    }
    header h1 { margin: 0; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }
    header .meta { color: var(--muted); font-size: 0.875rem; }
    .badge {
      display: inline-block; padding: 0.35rem 0.85rem; border-radius: 999px;
      font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    }
    .badge.pass { background: rgba(34,197,94,.2); color: var(--pass); }
    .badge.fail { background: rgba(239,68,68,.2); color: var(--fail); }
    .toolbar { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; align-items: center; }
    .toolbar input {
      flex: 1; min-width: 200px; padding: 0.6rem 1rem; border-radius: 8px;
      border: 1px solid var(--surface-2); background: var(--surface); color: var(--text);
    }
    .toolbar button {
      padding: 0.6rem 1rem; border-radius: 8px; border: 1px solid var(--surface-2);
      background: var(--surface); color: var(--text); cursor: pointer; font-size: 0.875rem;
    }
    .cards {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem; margin-bottom: 1.5rem;
    }
    .card {
      background: var(--surface); border-radius: var(--radius); padding: 1.1rem 1.25rem;
      box-shadow: var(--shadow); border-left: 4px solid var(--accent);
    }
    .card.pass { border-left-color: var(--pass); }
    .card.fail { border-left-color: var(--fail); }
    .card.broken { border-left-color: var(--broken); }
    .card.skip { border-left-color: var(--skip); }
    .card .label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
    .card .value { font-size: 1.75rem; font-weight: 700; margin-top: 0.25rem; }
    .chart-panel {
      background: var(--surface); border-radius: var(--radius); padding: 1.25rem;
      box-shadow: var(--shadow); margin-bottom: 1.5rem; display: flex; flex-wrap: wrap;
      gap: 2rem; align-items: center;
    }
    .chart-panel h2 { margin: 0 0 0.5rem; font-size: 1rem; color: var(--muted); width: 100%; }
    .bar-chart { display: flex; height: 28px; width: 280px; border-radius: 6px; overflow: hidden; }
    .bar-chart span { display: block; height: 100%; }
    .bar-chart .p { background: var(--pass); }
    .bar-chart .f { background: var(--fail); }
    .bar-chart .b { background: var(--broken); }
    .bar-chart .s { background: var(--skip); }
    .legend { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.8rem; color: var(--muted); }
    .legend span::before {
      content: ""; display: inline-block; width: 10px; height: 10px;
      border-radius: 2px; margin-right: 0.35rem; vertical-align: middle;
    }
    .legend .lp::before { background: var(--pass); }
    .legend .lf::before { background: var(--fail); }
    .legend .lb::before { background: var(--broken); }
    .legend .ls::before { background: var(--skip); }
    .accordion { display: flex; flex-direction: column; gap: 0.75rem; }
    .stage {
      background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow);
      overflow: hidden;
    }
    .stage-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.25rem; cursor: pointer; user-select: none;
      border-bottom: 1px solid transparent;
    }
    .stage.open .stage-header { border-bottom-color: var(--surface-2); }
    .stage-header h3 { margin: 0; font-size: 1rem; }
    .stage-meta { font-size: 0.8rem; color: var(--muted); }
    .stage-body { display: none; padding: 0 1rem 1rem; }
    .stage.open .stage-body { display: block; }
    .test-row {
      display: grid; grid-template-columns: 1fr auto auto; gap: 0.75rem;
      align-items: start; padding: 0.75rem 0; border-bottom: 1px solid var(--surface-2);
    }
    .test-row:last-child { border-bottom: none; }
    .status-chip {
      font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
      padding: 0.2rem 0.5rem; border-radius: 4px;
    }
    .status-chip.passed { background: rgba(34,197,94,.2); color: var(--pass); }
    .status-chip.failed, .status-chip.broken { background: rgba(239,68,68,.2); color: var(--fail); }
    .status-chip.skipped { background: rgba(100,116,139,.3); color: var(--skip); }
    .failure {
      grid-column: 1 / -1; font-size: 0.8rem; color: var(--fail);
      background: rgba(239,68,68,.08); padding: 0.5rem 0.75rem; border-radius: 6px;
      white-space: pre-wrap; font-family: ui-monospace, monospace;
    }
    .hidden { display: none !important; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div>
        <h1>{{ run_title }}</h1>
        <div class="meta">Generated {{ generated_at }}</div>
      </div>
      <span class="badge {{ 'pass' if overall_status == 'PASS' else 'fail' }}">{{ overall_status }}</span>
    </header>

    <div class="toolbar">
      <input type="search" id="search" placeholder="Search tests by name or status…" autocomplete="off"/>
      <button type="button" id="theme-toggle">Toggle theme</button>
      <button type="button" id="expand-all">Expand all</button>
      <button type="button" id="collapse-all">Collapse all</button>
    </div>

    <div class="cards">
      <div class="card"><div class="label">Total</div><div class="value">{{ total }}</div></div>
      <div class="card pass"><div class="label">Passed</div><div class="value">{{ passed }}</div></div>
      <div class="card fail"><div class="label">Failed</div><div class="value">{{ failed }}</div></div>
      <div class="card broken"><div class="label">Broken</div><div class="value">{{ broken }}</div></div>
      <div class="card skip"><div class="label">Skipped</div><div class="value">{{ skipped }}</div></div>
      <div class="card"><div class="label">Duration</div><div class="value">{{ duration_label }}</div></div>
    </div>

    <div class="chart-panel">
      <h2>Results distribution</h2>
      <div class="bar-chart" title="Pass / Fail / Broken / Skipped">
        {% if chart.passed_pct %}<span class="p" style="width:{{ chart.passed_pct }}%"></span>{% endif %}
        {% if chart.failed_pct %}<span class="f" style="width:{{ chart.failed_pct }}%"></span>{% endif %}
        {% if chart.broken_pct %}<span class="b" style="width:{{ chart.broken_pct }}%"></span>{% endif %}
        {% if chart.skipped_pct %}<span class="s" style="width:{{ chart.skipped_pct }}%"></span>{% endif %}
      </div>
      <svg width="120" height="120" viewBox="0 0 42 42" aria-hidden="true">
        <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="#334155" stroke-width="4"/>
        {% set offset = 0 %}
        {% if chart.passed %}
        <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="#22c55e" stroke-width="4"
          stroke-dasharray="{{ chart.passed_pct }} {{ 100 - chart.passed_pct }}"
          stroke-dashoffset="25" transform="rotate(-90 21 21)"/>
        {% endif %}
      </svg>
      <div class="legend">
        <span class="lp">Passed {{ chart.passed }}</span>
        <span class="lf">Failed {{ chart.failed }}</span>
        <span class="lb">Broken {{ chart.broken }}</span>
        <span class="ls">Skipped {{ chart.skipped }}</span>
      </div>
    </div>

    <div class="accordion" id="accordion">
      {% for group in stage_groups %}
      <div class="stage" data-stage>
        <div class="stage-header" role="button" tabindex="0" aria-expanded="false">
          <h3>{{ group.name }}</h3>
          <span class="stage-meta">{{ group.total }} tests{% if group.failed %} · {{ group.failed }} failed{% endif %}</span>
        </div>
        <div class="stage-body">
          {% for test in group.tests %}
          <div class="test-row" data-test data-name="{{ test.name|lower }} {{ test.status|lower }}">
            <div>
              <strong>{{ test.name }}</strong>
              {% if test.description %}<div class="meta" style="color:var(--muted);font-size:0.8rem">{{ test.description }}</div>{% endif %}
            </div>
            <span class="status-chip {{ test.status }}">{{ test.status }}</span>
            <span style="color:var(--muted);font-size:0.85rem">{{ test.duration_label }}</span>
            {% if test.failure_message %}
            <pre class="failure">{{ test.failure_message }}</pre>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  <script>
    const chartData = {{ chart.json|safe }};
    document.querySelectorAll('.stage-header').forEach(h => {
      h.addEventListener('click', () => {
        const stage = h.closest('.stage');
        stage.classList.toggle('open');
        h.setAttribute('aria-expanded', stage.classList.contains('open'));
      });
    });
    document.getElementById('search').addEventListener('input', e => {
      const q = e.target.value.trim().toLowerCase();
      document.querySelectorAll('[data-test]').forEach(row => {
        const name = row.getAttribute('data-name') || '';
        row.classList.toggle('hidden', q && !name.includes(q));
      });
      document.querySelectorAll('[data-stage]').forEach(stage => {
        const visible = stage.querySelectorAll('[data-test]:not(.hidden)').length;
        stage.classList.toggle('hidden', q && visible === 0);
      });
    });
    document.getElementById('expand-all').onclick = () =>
      document.querySelectorAll('.stage').forEach(s => { s.classList.add('open'); });
    document.getElementById('collapse-all').onclick = () =>
      document.querySelectorAll('.stage').forEach(s => { s.classList.remove('open'); });
    const root = document.documentElement;
    document.getElementById('theme-toggle').onclick = () => {
      const light = root.classList.toggle('light');
      root.classList.toggle('dark', !light);
      localStorage.setItem('testo-extent-theme', light ? 'light' : 'dark');
    };
    if (localStorage.getItem('testo-extent-theme') === 'light') {
      root.classList.add('light');
      root.classList.remove('dark');
    }
  </script>
</body>
</html>
