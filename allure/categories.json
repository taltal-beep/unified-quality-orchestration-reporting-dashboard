[
  {
    "name": "Database Issues",
    "matchedStatuses": ["broken", "failed"],
    "messageRegex": ".*(psycopg|postgres|sqlalchemy|database|db|deadlock|timeout).*"
  },
  {
    "name": "Network/Timeouts",
    "matchedStatuses": ["broken", "failed"],
    "messageRegex": ".*(timeout|timed out|connection|refused|reset|dns|socket|network).*"
  },
  {
    "name": "Validation Errors",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(validation|pydantic|schema|type error|assert).*"
  },
  {
    "name": "Auth Errors",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(401|unauthorized|token|jwt|bearer).*"
  },
  {
    "name": "Flaky Demo Failures",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*Flaky demo failure.*"
  }
]

