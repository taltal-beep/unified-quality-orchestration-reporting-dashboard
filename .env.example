# Unified Quality Orchestration (UQO) — copy to `.env` and fill in values.
# Never commit `.env` (see `.gitignore`).

# --- Streamlit (optional overrides) ---
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost

# --- InfluxDB 2.x (Grafana / time-series) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=uqo
INFLUXDB_TOKEN=your-influxdb-api-token

# --- Prometheus Pushgateway ---
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
PROMETHEUS_JOB_NAME=uqo

# --- InfluxDB integration (optional legacy naming) ---
# INFLUXDB_MEASUREMENT=uqo_test_run
