# Unified Quality Orchestration (UQO) — copy to `.env` and fill in values.
# Never commit `.env` (see `.gitignore`).

# --- Streamlit (optional overrides) ---
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost

# --- InfluxDB 2.x (Grafana / time-series) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=uqo
INFLUXDB_TOKEN=your-influxdb-api-token

# --- Prometheus Pushgateway ---
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
PROMETHEUS_JOB_NAME=uqo

# --- MinIO (S3-compatible artifact storage; matches docker-compose minio service) ---
MINIO_ROOT_USER=uqo_admin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
BUCKET_NAME=uqo-artifacts
# MINIO_PUBLIC_BASE_URL=http://localhost:9000

# --- Run history database (SQLModel / SQLAlchemy) ---
# If DATABASE_URL is set, it is the only connection string used (recommended).
# Otherwise, if POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB are all non-empty,
# UQO builds postgresql+psycopg://... from those vars (legacy docker-compose style).
# If neither applies, the default is file-backed SQLite: sqlite:///./uqo_history.db
#
# DATABASE_URL=sqlite:///./uqo_history.db
# DATABASE_URL=postgresql+psycopg://uqo_admin:admin@localhost:5432/uqo_history
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/uqo_history

# --- Postgres (run history DB; used when DATABASE_URL is unset and all three are set) ---
# POSTGRES_USER=uqo_admin
# POSTGRES_PASSWORD=admin
# POSTGRES_DB=uqo_history
# POSTGRES_HOST=localhost

# --- InfluxDB integration (optional legacy naming) ---
# INFLUXDB_MEASUREMENT=uqo_test_run
